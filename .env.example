# =====================================================================
#  siSuite — variabili d'ambiente (copia in `.env` e personalizza).
#  NON committare mai il file .env reale (vedi .gitignore).
#  Tutti i default qui sotto sono buoni per lo SVILUPPO LOCALE in Docker.
# =====================================================================

# ── PostgreSQL (container dedicato pgvector, isolato dal Postgres host) ──
POSTGRES_USER=sisuite_admin
POSTGRES_PASSWORD=dev_admin_pwd_change_me
POSTGRES_DB=sisuite
# porta host: 5433 per NON collidere col Postgres già installato (5432)
DB_HOST_PORT=5433

# Ruolo applicativo NOSUPERUSER/NOBYPASSRLS con cui si connette il backend.
# Creato dal bootstrap; la password va qui e nella DATABASE_URL del backend.
SISUITE_APP_PASSWORD=dev_app_pwd_change_me

# URL ADMIN (ruolo proprietario): lo usano migrate + bootstrap. NON il backend.
DATABASE_ADMIN_URL=postgres://sisuite_admin:dev_admin_pwd_change_me@db:5432/sisuite
# URL APP (ruolo sisuite_app, soggetto a RLS): lo usa il backend.
DATABASE_URL=postgres://sisuite_app:dev_app_pwd_change_me@db:5432/sisuite

# ── Auth (Supabase GoTrue) ──────────────────────────────────────────
# Segreto JWT condiviso (HS256) — modalità dev di default.
# Per la modalità ASIMMETRICA (RS256/JWKS, target del brief) vedi README §Auth.
GOTRUE_JWT_SECRET=dev_super_secret_jwt_key_change_me_min_32_chars
JWT_AUD=authenticated
JWT_ISSUER=http://localhost:9999

# Modalità del verificatore JWT del backend:
#   - HS256 (default dev): valorizza AUTH_JWT_SECRET = GOTRUE_JWT_SECRET, lascia AUTH_JWKS_URL vuoto
#   - RS256/asimmetrico: lascia AUTH_JWT_SECRET vuoto e valorizza AUTH_JWKS_URL
AUTH_JWT_SECRET=dev_super_secret_jwt_key_change_me_min_32_chars
AUTH_JWKS_URL=

# porta host di GoTrue
AUTH_HOST_PORT=9999

# ── Seed del primo tenant + utente Owner ────────────────────────────
TENANT_NAME=Si.Va.F. Informatica
TENANT_VERTICAL=software
TENANT_LOCALE=it-IT
TENANT_TIMEZONE=Europe/Rome
OWNER_EMAIL=owner@sisuite.local
OWNER_PASSWORD=Owner123!
OWNER_NAME=Titolare

# ── AI (Fase 2 — estrazione da linguaggio naturale) ─────────────────
# SEGRETO DI PIATTAFORMA — UNA sola chiave per TUTTI i tenant. Regole NON negoziabili:
#  - SOLO lato server: letta unicamente dal backend (config.ts). Mai nel frontend,
#    mai in una tabella leggibile dal tenant, mai nei log.
#  - Questo file (.env) è in .gitignore: NON finisce mai su GitHub.
#  - Dove metterla: QUI in dev / single-VPS; in produzione nel SECRETS MANAGER
#    dell'hosting (non un file). docker-compose la inietta SOLO nel servizio backend.
#  - Quota per-azienda: NON si usano chiavi diverse per cliente; il consumo si limita
#    con plan.entitlements.ai_quota_month (gating lato server).
#  - ON-PREM (futuro): la chiave NON deve MAI risiedere dal cliente. L'istanza on-prem
#    non chiama Anthropic direttamente: passa da un GATEWAY CLOUD della piattaforma che
#    custodisce la chiave; l'on-prem si autentica con un TOKEN DI LICENZA. (Backlog.)
# VUOTA = pipeline AI disattivata (resta il percorso form).
ANTHROPIC_API_KEY=
# Modello per l'estrazione. Default capace (claude-opus-4-8). L'MVP suggerisce un
# modello PICCOLO per l'estrazione frequente per contenere i costi: per quel profilo
# imposta es. claude-haiku-4-5 o claude-sonnet-4-6.
EXTRACTION_MODEL=claude-opus-4-8
# Confidenza minima sopra cui un'operazione proposta è auto-applicabile (basso rischio).
AI_AUTOAPPLY_THRESHOLD=0.85

# ── Backend ─────────────────────────────────────────────────────────
BACKEND_PORT=3010
BACKEND_HOST_PORT=3010
NODE_ENV=development
# CORS: origine del frontend in dev
CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite) ─────────────────────────────────────────────────
FRONTEND_HOST_PORT=5173
VITE_API_URL=http://localhost:3010
VITE_AUTH_URL=http://localhost:9999

# ── Adminer (ispezione DB, opzionale) ───────────────────────────────
ADMINER_HOST_PORT=8082

# ── MinIO (object storage, predisposto per Fase 2 — profilo opzionale) ──
MINIO_ROOT_USER=sisuite
MINIO_ROOT_PASSWORD=dev_minio_pwd_change_me
MINIO_HOST_PORT=9100
MINIO_CONSOLE_HOST_PORT=9101
